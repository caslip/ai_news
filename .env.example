# AI News Aggregator - Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Application Ports
# ===================
FRONTEND_PORT=3001
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ===================
# Database
# ===================
POSTGRES_USER=ai_news
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ai_news

# ===================
# Redis
# ===================
REDIS_PASSWORD=

# ===================
# Security
# ===================
# IMPORTANT: Change this to a strong random key in production!
SECRET_KEY=change-me-in-production-use-strong-random-key

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3001,http://frontend:3001

# ===================
# API Keys
# ===================

# OpenRouter API Key (for AI-powered article analysis)
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=

# GitHub Personal Access Token (for GitHub source monitoring)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ===================
# Cloudflare R2 (Image Storage)
# ===================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ===================
# Celery Configuration
# ===================
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2

# ===================
# Node Environment
# ===================
NODE_ENV=production
